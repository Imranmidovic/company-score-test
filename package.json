{
  "name": "company-research-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names trigger,server -c blue,green \"npx trigger.dev@latest dev\" \"npx tsx --env-file=.env src/server.ts\"",
    "dev:server": "npx tsx --env-file=.env src/server.ts",
    "dev:trigger": "npx trigger.dev@latest dev",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.0.0",
    "@trigger.dev/sdk": "^4.0.0",
    "ai": "^4.0.0",
    "express": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "trigger.dev": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
